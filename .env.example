# Meta Marketing API - Configuração
# =============================================
# Passo a passo para obter as credenciais:
#
# 1. Acesse developers.facebook.com e crie um App
# 2. Adicione o produto "Marketing API" ao App
# 3. Gere um System User Token com permissão "ads_read"
#    (Configurações do Negócio > Usuários do Sistema)
# 4. Copie este arquivo para ".env" e preencha os valores abaixo

META_ACCESS_TOKEN=seu_token_de_acesso_aqui
META_AD_ACCOUNT_ID=123456789
# ATENÇÃO: não inclua o prefixo "act_" no META_AD_ACCOUNT_ID

PORT=3001
