{
  "name": "meta-leads-dashboard",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite\"",
    "dev:lumina-dental": "CLIENT=lumina-dental PORT=3001 concurrently \"node server.js\" \"vite --port 5173\"",
    "dev:primordialle": "CLIENT=primordialle PORT=3002 concurrently \"node server.js\" \"vite --port 5174\"",
    "dev:novo-cliente": "CLIENT=novo-cliente PORT=3003 concurrently \"node server.js\" \"vite --port 5175\"",
    "dev:all": "concurrently \"npm run dev:lumina-dental\" \"npm run dev:primordialle\" \"npm run dev:novo-cliente\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "http-proxy-middleware": "^3.0.5",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^5.24.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-map-gl": "^8.1.1",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.17",
    "vite": "^5.3.0"
  }
}
